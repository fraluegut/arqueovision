{
  "title": "ArqueoVision",
  "uid": "arqueovision-main",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total inferencias",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM inference_logs WHERE status = 'ok'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Errores",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM inference_logs WHERE status = 'error'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Latencia media (ms)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(latency_ms)::numeric, 1) AS value FROM inference_logs WHERE status = 'ok'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Tasa de éxito (%)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN status='ok' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 1) AS value FROM inference_logs",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Inferencias por hora",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', timestamp) AS time, COUNT(*) AS inferencias FROM inference_logs WHERE $__timeFilter(timestamp) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Top predicciones",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT prediction AS metric, COUNT(*) AS value FROM inference_logs WHERE status='ok' AND prediction IS NOT NULL AND $__timeFilter(timestamp) GROUP BY prediction ORDER BY value DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Latencia p95 por clase (ms)",
      "type": "bargauge",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT prediction AS metric, ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY latency_ms)::numeric, 1) AS value FROM inference_logs WHERE status='ok' AND prediction IS NOT NULL AND $__timeFilter(timestamp) GROUP BY prediction ORDER BY value DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "title": "Peticiones HTTP / segundo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total{app_name=\"arqueovision-api\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Latencia HTTP p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=\"/predict-image\"}[5m]))",
          "legendFormat": "p95 /predict-image",
          "refId": "A"
        }
      ]
    }
  ]
}
